class Solution(object):
    def romanToInt(self, s):
        """
        :type s: str
        :rtype: int
        """
        bang_tra = {
            'I': 1, 'V': 5, 'X': 10, 'L': 50,
            'C': 100, 'D': 500, 'M': 1000
        }
        
        tong = 0
        n = len(s)
        
        for i in range(n):
            gia_tri_hien_tai = bang_tra[s[i]]
            
            if i + 1 < n and gia_tri_hien_tai < bang_tra[s[i+1]]:
                tong -= gia_tri_hien_tai
            else:
                tong += gia_tri_hien_tai
                
        return tong
